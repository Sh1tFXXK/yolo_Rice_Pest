QPushButton[iconMode=&quot;true&quot;] {
    padding: 12px 5px;
    text-align: center;
    min-width: 60px;
    max-width: 60px;
}
QPushButton[iconMode=&quot;true&quot;]:hover::after {
    content: attr(tooltip);
    position: absolute;
    left: 70px;
    top: 50%;
    background: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 12px;
    white-space: nowrap;
    z-index: 1000;
}</string>
